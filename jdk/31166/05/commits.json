[{"commit":{"message":"Make abbreviated GC cycle time predictions more accurate"},"files":[{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahAdaptiveHeuristics.cpp"}],"sha":"70e3c8ea32e5d4aebba57a91eca9e7cf873ca61c"},{"commit":{"message":"Misc improvements related to abbreviated cycles\n\nPlanning to integrate these as separate PRs, but combining everything\ntogether for CI performance testing:\n\n1. Only count abbreviated GC times during learning, and count them as\n   half a normal GC cycle time.\n2. Degen out of cycle should also impose triggering penalties\n3. Only rebuild freeset once during abbreviated GC cycles\n\nThese are in addition to the original fix in this PR, which is to reset\nthe reserves at final mark when we decide this will be an abbreviated GC\ncycle."},"files":[{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahAdaptiveHeuristics.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahAdaptiveHeuristics.hpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahHeuristics.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahHeuristics.hpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahOldHeuristics.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahOldHeuristics.hpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahControlThread.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahDegeneratedGC.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahGeneration.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahGenerationalControlThread.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahOldGeneration.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahRegulatorThread.cpp"}],"sha":"72c072eae98d7970754b2fc29cfafaa1f89f85db"},{"commit":{"message":"Fix freeset rebuild and future reserves for abbreviated cycles"},"files":[{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahConcurrentGC.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahDegeneratedGC.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahFreeSet.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahGeneration.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/shenandoahGenerationalHeap.cpp"}],"sha":"ec36ac621acd0338753df26351783b8b418ad601"},{"commit":{"message":"Borrow fix from PR 31178"},"files":[{"filename":"src\/hotspot\/share\/gc\/shenandoah\/c2\/shenandoahSupport.cpp"}],"sha":"ce640310fa4596a95a7abddded2baadeff07c1de"},{"commit":{"message":"reorder includes"},"files":[{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahHeuristics.cpp"}],"sha":"02159b8af9bdfc29b95aa91b9f39a0f75b549a0e"},{"commit":{"message":"Reset reserves to zero for abbreviated cycles"},"files":[{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahHeuristics.cpp"}],"sha":"45d5da0a146b4f636cb1e5def63b00e09fe8eea6"}]