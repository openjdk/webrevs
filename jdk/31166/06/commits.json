hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahHeuristics.cpp"}],"sha":"437903ffd2eceb20bdfb23dd79bd99e5602de1d0"},{"commit":{"message":"Merge branch 'master' of https:\/\/git.openjdk.org\/jdk into fix-assert-for-global-gc"},"files":[{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahHeuristics.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahHeuristics.hpp"}],"sha":"c4e7365fc7eae13e45f3a4b66e424ca718537bac"},{"commit":{"message":"Revert change borrowed from different PR"},"files":[],"sha":"5ffe2f55862fd5d0f928c488be664f65877a82b2"},{"commit":{"message":"Make abbreviated GC cycle time predictions more accurate"},"files":[],"sha":"70e3c8ea32e5d4aebba57a91eca9e7cf873ca61c"},{"commit":{"message":"Misc improvements related to abbreviated cycles\n\nPlanning to integrate these as separate PRs, but combining everything\ntogether for CI performance testing:\n\n1. Only count abbreviated GC times during learning, and count them as\n   half a normal GC cycle time.\n2. Degen out of cycle should also impose triggering penalties\n3. Only rebuild freeset once during abbreviated GC cycles\n\nThese are in addition to the original fix in this PR, which is to reset\nthe reserves at final mark when we decide this will be an abbreviated GC\ncycle."},"files":[{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahHeuristics.cpp"},{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahHeuristics.hpp"}],"sha":"72c072eae98d7970754b2fc29cfafaa1f89f85db"},{"commit":{"message":"Fix freeset rebuild and future reserves for abbreviated cycles"},"files":[],"sha":"ec36ac621acd0338753df26351783b8b418ad601"},{"commit":{"message":"Borrow fix from PR 31178"},"files":[],"sha":"ce640310fa4596a95a7abddded2baadeff07c1de"},{"commit":{"message":"reorder includes"},"files":[{"filename":"src\/hotspot\/share\/gc\/shenandoah\/heuristics\/shenandoahHeuristics.cpp"}],"sha":"02159b8af9bdfc29b95aa91b9f39a0f75b549a0e"},{"commit